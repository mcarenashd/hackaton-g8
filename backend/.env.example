# =====================================================================
# AquaGuía — variables de entorno
# =====================================================================
# Copia este archivo a `.env` y rellena los valores.
# Mientras NO existan estas variables, el backend usa stubs realistas
# (la app funciona end-to-end igual, pero las imágenes y el análisis
# de fotos no son reales). Reinicia `npm run dev` tras cambiar esto.

# --- Servidor ---
PORT=4000

# --- Microsoft Copilot / Azure OpenAI ---
# Endpoint de tu recurso Azure OpenAI (sin barra final).
# Lo encuentras en: portal.azure.com → tu recurso → "Keys and Endpoint".
AZURE_OPENAI_ENDPOINT=https://TU-RECURSO.openai.azure.com

# Una de las dos keys (KEY 1 o KEY 2).
AZURE_OPENAI_KEY=

# Nombres de los DEPLOYMENTS que crees en Azure AI Studio.
# (no son los nombres de los modelos; son los nombres que TÚ les pongas
# al desplegarlos.)
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_IMAGE_DEPLOYMENT=dall-e-3

# Versión de la API de Azure OpenAI.
AZURE_OPENAI_API_VERSION=2024-08-01-preview
